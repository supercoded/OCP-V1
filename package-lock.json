      "version": "0.1.0",
      "dependencies": {
        "@ocp/offline-core": "0.1.0"
      }
    },
    "node_modules/@ocp/desktop-app": {
      "resolved": "apps/desktop",
      "link": true
    },
    "node_modules/@ocp/mobile-app": {
      "resolved": "apps/mobile",
      "link": true
    },
    "node_modules/@ocp/offline-core": {
      "resolved": "packages/offline-core",
