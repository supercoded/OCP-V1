{
  "name": "ocp-v1-offline-app",
  "version": "0.1.0",
  "private": true,
  "description": "Offline-first phone and desktop communication app scaffold for Meshtastic-compatible radios.",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "test": "node --test",
    "build:desktop": "bash scripts/build-desktop.sh",
    "build:android": "bash scripts/build-android.sh",
    "validate:field": "bash scripts/field-validation.sh",
    "firmware:list": "node scripts/update-meshtastic-firmware.js list",
    "firmware:download": "node scripts/update-meshtastic-firmware.js download",
    "firmware:flash": "node scripts/update-meshtastic-firmware.js flash",
    "desktop:dev": "npm run dev --workspace=@ocp/desktop",
    "desktop:build": "npm run build --workspace=@ocp/desktop",
    "desktop:dist:win": "npm run dist:win --workspace=@ocp/desktop",
    "desktop:build:linux": "npm run build --workspace=@ocp/desktop && npm run dist:linux --workspace=@ocp/desktop",
    "desktop:dist:linux": "npm run dist:linux --workspace=@ocp/desktop"
  },
  "dependencies": {
    "protobufjs": "^8.7.0"
  },
  "devDependencies": {
    "electron": "34.0.0"
  }
}